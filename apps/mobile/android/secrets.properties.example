# ===== TEMPLATE - copy thành `secrets.properties` (gitignored) rồi điền giá trị thật =====
# secrets.properties chứa secret project-local, KHÔNG commit. File .example này thì commit được.
# Build đọc theo thứ tự: secrets.properties → (-P / ~/.gradle/gradle.properties) cho CI.

# Tuya Smart Life App SDK (Android) - lấy từ Tuya IoT console (app SDK đã tạo).
THING_SMART_APPKEY=your_tuya_appkey
THING_SMART_SECRET=your_tuya_appsecret

# Release signing - keystore đặt ở apps/mobile/android/app/<file>.keystore (gitignored).
WALRUS_RELEASE_STORE_FILE=walrus-release.keystore
WALRUS_RELEASE_STORE_PASSWORD=your_store_password
WALRUS_RELEASE_KEY_ALIAS=walrus
WALRUS_RELEASE_KEY_PASSWORD=your_key_password
