# ===== Backend env (cool-bath) =====
# Copy → .env và điền giá trị thật. .env KHÔNG commit (xem .gitignore).
# Secret (service_role, Tuya Access Secret) là SERVER-ONLY, tuyệt đối không vào client/bundle.

NODE_ENV=development
PORT=3000

# ---- Supabase / Postgres (Prisma) ----
# Pooled (pgbouncer) cho runtime serverless:
DATABASE_URL=postgresql://postgres:<password>@<project>.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct (cho prisma migrate):
DIRECT_URL=postgresql://postgres:<password>@<project>.supabase.com:5432/postgres
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=<anon_public_key>            # dùng làm apikey cho /auth/v1/*
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>   # SERVER-ONLY

# ---- Tuya Cloud OpenAPI (KHÁC AppKey/AppSecret của App SDK mobile) ----
# Endpoint phải khớp Data Center của Cloud Project (dự án = Central Europe):
#   Central Europe = https://openapi.tuyaeu.com        (mặc định cho dự án này)
#   Western Europe = https://openapi-weaz.tuyaeu.com
#   Western America = https://openapi.tuyaus.com  | India = https://openapi.tuyain.com
TUYA_OPENAPI_ENDPOINT=https://openapi.tuyaeu.com
TUYA_ACCESS_ID=<cloud_project_access_id>          # = client_id
TUYA_ACCESS_SECRET=<cloud_project_access_secret>  # = secret, SERVER-ONLY
TUYA_APP_SCHEMA=<app_sdk_channel_schema>          # cho GET /v2.0/apps/{schema}/users
TUYA_APP_BIZ_TYPE=<biz_type_so>                    # mã định danh app (App Push), lấy sau khi subscribe
TUYA_APP_TEMPLATE_ID=<PUSH_xxxxxxxxxx>             # template app-push đã duyệt (biến ${title}/${content}) cho gửi free-form

# ---- Cron nội bộ (Vercel Cron) ----
CRON_SECRET=<random_long_secret>                  # gửi qua header x-cron-secret, SERVER-ONLY

# ---- Firebase Cloud Messaging (M3 push) — service account SERVER-ONLY ----
FCM_PROJECT_ID=<firebase_project_id>
FCM_CLIENT_EMAIL=<xxx@<project>.iam.gserviceaccount.com>
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"  # SERVER-ONLY, giữ \n escaped
PUSH_API_KEY=<random_long_secret>                 # bảo vệ POST/DELETE /push/tokens (mobile gửi qua header x-api-key)
