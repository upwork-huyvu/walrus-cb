{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.ts": {
      "includeFiles": "node_modules/.prisma/client/**"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "crons": [
    {
      "path": "/internal/cron/process-delete-jobs",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/internal/cron/process-reminders",
      "schedule": "0 1 * * *"
    }
  ]
}
